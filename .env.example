# ---------------------------------------------------------------
# Required
# ---------------------------------------------------------------

DISCORD_TOKEN=
GUILD_ID=

MONGO_URI=

STAFF_ROLE_ID=
SENIOR_STAFF_ROLE_ID=
OWNER_ROLE_ID=
MENTOR_ROLE_ID=

# ---------------------------------------------------------------
# Optional
# ---------------------------------------------------------------

# MongoDB database name. Defaults to "foundry".
MONGO_DB_NAME=

# Channel where closed ticket transcripts are posted.
# If unset, the archive handler is not registered.
ARCHIVE_CHANNEL_ID=

# MongoDB collection names. Defaults are set in the application.
CHANNEL_COLLECTION=
ROLE_COLLECTION=
USER_COLLECTION=

# Set to true to enable debug logging.
DEBUG_MODE=

# Wise Old Man group ID for the docket achievements panel.
# Find your group at https://wiseoldman.net/groups
# If unset, the AchievementsPanel is disabled.
WOM_GROUP_ID=
