# ---------------------------------------------------------------
# Required
# ---------------------------------------------------------------

DISCORD_TOKEN=
GUILD_ID=

# PostgreSQL connection string
DATABASE_URL=

STAFF_ROLE_ID=
SENIOR_STAFF_ROLE_ID=
OWNER_ROLE_ID=
MENTOR_ROLE_ID=

# ---------------------------------------------------------------
# Optional
# ---------------------------------------------------------------

# Set to true to enable debug logging.
DEBUG_MODE=

# Metrics reporting - POST metrics to api-backend every 5 minutes.
# API_BACKEND_URL is the internal URL of the api-backend service.
# METRICS_API_KEY is a shared key used by all reporting services (managed by Infisical).
API_BACKEND_URL=
METRICS_API_KEY=
